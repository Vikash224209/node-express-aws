{
  "name": "node-express-aws",
  "version": "1.0.0",
  "description": "Production-ready Node.js / Express API deployable to AWS EC2 via Docker",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
    "test":    "jest --forceExit --coverage",
    "lint":    "eslint src/ tests/",
    "lint:fix":"eslint src/ tests/ --fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.19.2",
    "helmet":  "^7.1.0",
    "morgan":  "^1.10.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint":         "^8.57.0",
    "jest":           "^29.7.0",
    "nodemon":        "^3.1.3",
    "supertest":      "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}

